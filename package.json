{
  "name": "expecto-cli",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "A personal, markdown-driven, Claude-like code agent runtime.",
  "bin": {
    "expecto": "./dist/src/cli/entry.js"
  },
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "check": "tsc -p tsconfig.json --noEmit",
    "dev": "node --experimental-strip-types src/cli/entry.ts",
    "dev:init": "EXPECTO_FORCE_THEME_PICKER=1 node --experimental-strip-types src/cli/entry.ts",
    "dev:watch:init": "EXPECTO_FORCE_THEME_PICKER=1 node --watch-path=src --watch-path=package.json --watch-path=tsconfig.json --experimental-strip-types src/cli/entry.ts",
    "install:local": "bash ./scripts/install-local-expecto.sh",
    "test": "node --experimental-strip-types --test $(find tests -name '*.test.ts' -print)"
  },
  "dependencies": {
    "@types/blessed": "^0.1.27",
    "better-sqlite3": "^11.10.0",
    "execa": "^9.6.0",
    "globby": "^14.1.0",
    "gray-matter": "^4.0.3",
    "neo-blessed": "^0.2.0",
    "picocolors": "^1.1.1",
    "zod": "^3.24.3"
  },
  "devDependencies": {
    "@types/node": "^22.13.14",
    "typescript": "^5.8.2"
  }
}
